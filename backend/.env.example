# AutoPrism - Environment Variables
# ============================================
# DATABASE (Docker PostgreSQL)
# ============================================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/autoprism
DATABASE_SYNC_URL=postgresql://postgres:postgres@localhost:5432/autoprism

# ============================================
# SECURITY
# ============================================
SECRET_KEY=autoprism-dev-secret-key-change-in-production

# ============================================
# AI API
# ============================================
AI_API_BASE=https://api.openai.com/v1
AI_API_KEY=your_platform_api_key
AI_MODEL=gpt-4o


# ============================================
# APPLICATION
# ============================================
DEBUG=true
APP_NAME=AutoPrism
APP_VERSION=1.0.0
CRAWL_CACHE_TTL=3600
AI_CACHE_TTL=86400

